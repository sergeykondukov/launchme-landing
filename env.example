# Copy to .env for local builds. Set the same names in Netlify / Vercel / GitHub Actions.
# Values come from Supabase Dashboard → Project Settings → API.
#
# NEXT_PUBLIC_* matches common Next.js naming; this repo is static HTML but keeps
# the same names so ops can reuse secrets across app and site.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Paddle checkout page (/paddle?_ptxn=txn_xxx)
# Client token is intended for browser use via build-time injection into js/paddle-config.js.
PADDLE_CLIENT_TOKEN=YOUR_PADDLE_CLIENT_TOKEN
# Allowed values: sandbox or production
PADDLE_ENV=production
